<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.3" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>한국 주식 자동매매 봇 — 매일 08:50 자동 시작, 장 마감(15:30) 후 자동 종료</Description>
  </RegistrationInfo>
  <Triggers>
    <!-- 평일 08:50 시작 (한국 장 08:55 prepare_day 직전 여유 5분) -->
    <CalendarTrigger>
      <StartBoundary>2026-01-01T08:50:00</StartBoundary>
      <ScheduleByWeek>
        <WeeksInterval>1</WeeksInterval>
        <DaysOfWeek>
          <Monday />
          <Tuesday />
          <Wednesday />
          <Thursday />
          <Friday />
        </DaysOfWeek>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT10H</ExecutionTimeLimit>
    <!-- 비정상 종료 시 1분 후 최대 3회 재시도 -->
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>3</Count>
    </RestartOnFailure>
    <Enabled>true</Enabled>
  </Settings>
  <Actions>
    <Exec>
      <Command>D:\source\autotrader\run.bat</Command>
      <WorkingDirectory>D:\source\autotrader</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
