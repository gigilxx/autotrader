# 한국투자증권 KIS Open API 자격증명
# 모의투자와 실전은 각각 별도 앱키/시크릿을 발급받아야 함
KIS_APPKEY=your_appkey_here
KIS_APPSECRET=your_appsecret_here
KIS_CANO=12345678          # 종합계좌번호 앞 8자리
KIS_ACNT_PRDT_CD=01        # 계좌상품코드 뒤 2자리 (위탁계좌 보통 01)
KIS_ENV=mock               # mock=모의투자 / real=실전투자 (모의로 먼저 시작)

# 텔레그램 알림 (선택 — 없으면 콘솔 출력으로 폴백)
# 봇 생성: @BotFather 에서 /newbot
# chat_id 확인: @userinfobot 에 /start
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# 관심종목 (쉼표 구분) — UI/텔레그램으로 설정한 값이 우선 적용됨
# 초기 설정 시 또는 DB가 없을 때만 사용 (예: WATCHLIST=005930,000660)
WATCHLIST=

# 봇 설정
POLL_SEC=3                 # 시세 폴링 간격(초, 기본 2)

# UI / FastAPI (Phase 4)
UI_SECRET_KEY=             # POST /kill /resume 인증 키 (비워두면 인증 생략)
STATE_DB=state.db          # SQLite 경로 (봇·API 서버 공유)
LOG_FILE=logs/autotrader.log
