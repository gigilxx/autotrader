# FastAPI 서버 URL — 브라우저(클라이언트) 사이드 GET 호출용 (개발: http://localhost:8000, 배포: https://your-api.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# FastAPI 서버 URL — Next.js 서버 사이드 프록시(POST)용
# Node.js fetch가 localhost를 IPv6(::1)로 해석해 uvicorn(IPv4)과 충돌하므로 127.0.0.1 명시
# 미설정 시 기본값: http://127.0.0.1:8000
INTERNAL_API_URL=http://127.0.0.1:8000

# FastAPI 인증 키 (UI_SECRET_KEY와 동일하게 설정)
# NEXT_PUBLIC_ 없이 서버 사이드 전용 — 브라우저에 노출되지 않음
API_SECRET=your-secret-key
